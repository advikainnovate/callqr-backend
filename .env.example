# Server Configuration
PORT=4000
NODE_ENV=development
BACKEND_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# Database Configuration
# Option 1: Full DATABASE_URL (recommended)
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# Option 2: Individual credentials (alternative)
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=qr_calling_db

# CORS Configuration
ALLOWED_ORIGINS=*

# Security
JWT_SECRET=supersecretjwtkey-change-this-in-production
JWT_ACCESS_TOKEN_EXPIRES_IN=59m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Admin Configuration
# Comma-separated list of admin user IDs (UUIDs)
ADMIN_USER_IDS=

# WebRTC Configuration
STUN_SERVER=stun:stun.l.google.com:19302
TURN_SERVER=
TURN_USERNAME=
TURN_PASSWORD=

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Twilio Configuration (for SMS/Phone Verification)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Exotel Configuration (Primary for India +91)
EXOTEL_ACCOUNT_SID=your_exotel_sid
EXOTEL_API_KEY=your_exotel_key
EXOTEL_API_TOKEN=your_exotel_token
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_SENDER_ID=your_sender_id
EXOTEL_DLT_ENTITY_ID=your_dlt_entity_id
EXOTEL_DLT_OTP_TEMPLATE_ID=your_dlt_template_id
EXOTEL_MCV_NUMBER=+91XXXXXXXXXX

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@yourapp.com

# Cloudinary Configuration (for media uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Call Reliability (Grace Period)
# Time to wait (ms) before ending a call after a socket disconnects (default 30s)
CALL_DISCONNECT_GRACE_PERIOD_MS=30000
# Delay (ms) before sending a wake-up push notification after disconnect (default 3s)
CALL_WAKEUP_PUSH_DELAY_MS=3000

# Optional: Logging
LOG_LEVEL=info

# Development/Testing
TEST_EMAIL=test.user@example.com

# ─── Firebase (Push Notifications) ───────────────────────────────────────────
# OPTION A: Path to downloaded service account JSON (easiest for local dev)
# Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_SERVICE_ACCOUNT=./serviceAccountKey.json
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# OPTION B: Individual values from the service account JSON (best for prod / cloud hosting)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"