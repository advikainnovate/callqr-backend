meta {
  name: List My Codes
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/api/qr-codes/my-codes
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

tests {
  test("Should list my QR codes successfully", function() {
    expect(res.status).to.equal(200);
    expect(res.body.success).to.be.true;
    expect(res.body.data.qrCodes).to.be.an('array');
  });
}
