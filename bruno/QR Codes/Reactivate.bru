meta {
  name: Reactivate
  type: http
  seq: 8
}

patch {
  url: {{baseUrl}}/api/qr-codes/{{qrCodeId}}/reactivate
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

tests {
  test("Should reactivate QR code successfully", function() {
    expect(res.status).to.equal(200);
    expect(res.body.success).to.be.true;
    expect(res.body.data.status).to.equal('active');
  });
}
