meta {
  name: Get Image
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/api/qr-codes/image/{{qrToken}}
  body: none
  auth: none
}

tests {
  test("Should get QR code image successfully", function() {
    expect(res.status).to.equal(200);
    expect(res.body.success).to.be.true;
    expect(res.body.data.image).to.be.a('string');
    expect(res.body.data.image).to.include('data:image');
  });
}
