meta {
  name: Get Call Details
  type: http
  seq: 13
}

get {
  url: {{baseUrl}}/api/admin/calls/:callId
  body: none
  auth: bearer
}

params:path {
  callId: call-id-here
}

auth:bearer {
  token: {{authToken}}
}

docs {
  Get detailed call information:
  - Call details
  - Caller and receiver info
  - QR code used
  - Call duration
}
