meta {
  name: List Globally Blocked Users
  type: http
  seq: 35
}

get {
  url: {{baseUrl}}/api/admin/users/global-blocked/list
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

tests {
  test("Should list globally blocked users", function() {
    expect(res.status).to.equal(200);
    expect(res.body.success).to.be.true;
    expect(res.body.data.users).to.be.an('array');
  });
}
