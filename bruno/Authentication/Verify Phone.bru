meta {
  name: Verify Phone
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/api/auth/verify-phone
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "otp": "123456"
  }
}

docs {
  Verify phone number with OTP code.
  Requires authentication.
  OTP must be 6 digits.
}
