meta {
  name: Verify Phone
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/users/verify/phone
  body: json
  auth: none
}

body:json {
  {
    "phone": "{{testPhone}}"
  }
}

tests {
  test("Should verify phone successfully", function() {
    expect(res.status).to.equal(200);
    expect(res.body.success).to.be.true;
    expect(res.body.data.exists).to.be.a('boolean');
  });
}
