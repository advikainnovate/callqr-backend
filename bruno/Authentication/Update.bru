meta {
  name: Update
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/api/users/{{userId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "username": "updated_{{testUsername}}"
  }
}

tests {
  test("Should update user successfully", function() {
    expect(res.status).to.equal(200);
    expect(res.body.success).to.be.true;
    expect(res.body.data.username).to.include('updated_');
  });
}
