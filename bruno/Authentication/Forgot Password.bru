meta {
  name: Forgot Password
  type: http
  seq: 10
}

post {
  url: {{baseUrl}}/api/auth/forgot-password
  body: json
  auth: none
}

body:json {
  {
    "username": "testuser"
  }
}

docs {
  Request password reset OTP.
  OTP will be sent to user's verified phone number.
  Returns user ID needed for reset password step.
  OTP expires in 10 minutes.
}
