meta {
  name: Reset Password
  type: http
  seq: 11
}

post {
  url: {{baseUrl}}/api/auth/reset-password
  body: json
  auth: none
}

body:json {
  {
    "userId": "user-id-from-forgot-password",
    "otp": "123456",
    "newPassword": "newpassword123"
  }
}

docs {
  Reset password using OTP verification.
  Requires:
  - userId from forgot-password response
  - OTP from SMS (6 digits)
  - New password (min 6 characters)
  
  After successful reset, user can login with new password.
}
