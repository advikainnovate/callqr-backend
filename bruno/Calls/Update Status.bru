meta {
  name: Update Status
  type: http
  seq: 5
}

patch {
  url: {{baseUrl}}/api/calls/{{callId}}/status
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "status": "connected"
  }
}

tests {
  test("Should update call status successfully", function() {
    expect(res.status).to.equal(200);
    expect(res.body.success).to.be.true;
    expect(res.body.data.status).to.equal('connected');
  });
}
