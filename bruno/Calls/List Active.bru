meta {
  name: List Active
  type: http
  seq: 8
}

get {
  url: {{baseUrl}}/api/calls/active/list
  body: none
  auth: bearer
}

headers {
  x-guest-id: {{guestId}}
}

auth:bearer {
  token: {{authToken}}
}

tests {
  test("Should list active calls successfully", function() {
    expect(res.status).to.equal(200);
    expect(res.body.success).to.be.true;
    expect(res.body.data.calls).to.be.an('array');
  });
}
