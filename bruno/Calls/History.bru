meta {
  name: History
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/api/calls/history/all?limit=50
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

tests {
  test("Should get call history successfully", function() {
    expect(res.status).to.equal(200);
    expect(res.body.success).to.be.true;
    expect(res.body.data.calls).to.be.an('array');
  });
}
