meta {
  name: Details
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/calls/{{callId}}
  body: none
  auth: bearer
}

headers {
  x-guest-id: {{guestId}}
}

auth:bearer {
  token: {{authToken}}
}

tests {
  test("Should get call details successfully", function() {
    expect(res.status).to.equal(200);
    expect(res.body.success).to.be.true;
    expect(res.body.data.id).to.equal(env.callId);
    expect(res.body.data.status).to.be.a('string');
  });
}
