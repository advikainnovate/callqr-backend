meta {
  name: Cancel
  type: http
  seq: 7
}

delete {
  url: {{baseUrl}}/api/subscriptions/{{subscriptionId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

tests {
  test("Should cancel subscription successfully", function() {
    expect(res.status).to.equal(200);
    expect(res.body.success).to.be.true;
    expect(res.body.data.status).to.equal('canceled');
  });
}
