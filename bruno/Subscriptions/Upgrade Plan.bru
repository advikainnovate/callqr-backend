meta {
  name: Upgrade Plan
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/api/subscriptions/upgrade
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "plan": "enterprise"
  }
}

tests {
  test("Should upgrade plan successfully", function() {
    expect(res.status).to.equal(200);
    expect(res.body.success).to.be.true;
    expect(res.body.data.plan).to.equal('enterprise');
    expect(res.body.data.status).to.equal('active');
  });
}
