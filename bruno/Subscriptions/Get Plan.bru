meta {
  name: Get Plan
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/api/subscriptions/plan
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

tests {
  test("Should get user plan successfully", function() {
    expect(res.status).to.equal(200);
    expect(res.body.success).to.be.true;
    expect(res.body.data.plan).to.be.a('string');
  });
}
